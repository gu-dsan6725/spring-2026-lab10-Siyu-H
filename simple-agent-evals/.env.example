# API Keys for Simple Agent Evals
# Copy this file to .env and fill in your API keys

# Anthropic (REQUIRED for Claude Haiku - the agent's brain)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Braintrust (REQUIRED for observability and evals - FREE, no credit card required)
# Sign up and get your FREE key at: https://www.braintrust.dev/
BRAINTRUST_API_KEY=your-braintrust-api-key-here

# Braintrust Project Name (REQUIRED)
# This is the project where traces and eval results will appear
BRAINTRUST_PROJECT=project_name:simple-agent-evals

# Note: No API keys needed for the tools!
# - DuckDuckGo Search: Free, no key needed
# - Open-Meteo Weather: Free, no key needed
# - OSRM Directions: Free, no key needed
